# Servidor
PORT=3000
NODE_ENV=development

# MongoDB (local o Atlas)
# Ejemplo local: mongodb://localhost:27017/acordes-app
# Ejemplo Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/acordes-app
MONGODB_URI=mongodb://localhost:27017/acordes-app

# JWT
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=7d

# CORS (orígenes permitidos separados por coma)
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# Admin inicial (se crea con el script seed)
ADMIN_EMAIL=admin@acordes-app.com
ADMIN_PASSWORD=cambiar-en-primer-login
ADMIN_NAME=Admin
